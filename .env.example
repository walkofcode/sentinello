# Sentinello environment variables — all optional, with sensible defaults.
# Copy this file to `.env` (or `.env.local` for the web app) and edit as needed.

# Path to the shared SQLite file. apps/web and apps/worker MUST resolve to the same path,
# or the worker writes scans the portal never reads.
# Default (unset): <repo>/data/sentinello.sqlite for local dev; /app/data/sentinello.sqlite in Docker.
SENTINELLO_DB_PATH=

# Public-facing URL of the portal. Used by the worker in notification payloads as the link back.
# Default: http://localhost:3870 in Docker and local dev
SENTINELLO_PORTAL_BASE_URL=http://localhost:3870

# Attribution shown on mutes and mute-lifts in the portal.
# Default: anonymous
ME_NAME=

# Web server port (inside the container or local process).
# Default: 3000 in Docker, 3870 in `pnpm dev`.
PORT=3000

# Version label shown in the UI footer and /api/health. Normally baked into the Docker image
# at build time via --build-arg SENTINELLO_VERSION=X.Y.Z (handled by .github/workflows/docker-publish.yml).
# Unset in local dev → footer shows "dev".
SENTINELLO_VERSION=

# Update-check feed (GitHub Releases API by default). The portal calls this at most once per 6h
# to compare the running version against the latest release.
# Default: https://api.github.com/repos/walkofcode/sentinello/releases/latest
# Set to "off" to fully disable update checks (equivalent to flipping update_checks_enabled=false
# in app_config). For self-hosting forks, point this at your own fork's releases endpoint.
SENTINELLO_UPDATE_FEED_URL=
