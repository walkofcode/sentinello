        "react": "19.2.5",
        "react-dom": "19.2.5",
        "tailwind-merge": "3.5.0"
    },
    "devDependencies": {
        "@tailwindcss/postcss": "4.2.4",
        "@types/node": "25.6.0",
        "@types/react": "19.2.14",
        "@types/react-dom": "19.2.3",
        "postcss": "8.5.13",
        "tailwindcss": "4.2.4"
