# Google Analytics 4 Measurement ID. When set, the GA script loads on every page; when unset,
# no analytics script is emitted. Safe to leave blank in development.
NEXT_PUBLIC_GA_ID=

# Dev only: comma-separated hosts allowed to load /_next dev resources (HMR + client chunks) when
# the dev server is reached through a tunnel instead of localhost. Without this, Next 16 blocks
# those cross-origin requests and the page never hydrates (nothing is clickable). Wildcards work.
# Example: NEXT_DEV_ORIGINS=*.tunnel.example.com
NEXT_DEV_ORIGINS=
